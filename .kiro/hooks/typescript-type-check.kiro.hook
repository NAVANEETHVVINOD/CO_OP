{
  "enabled": true,
  "name": "TypeScript type check",
  "description": "Checks TypeScript types on saved .ts/.tsx files in apps/web/src/ and suggests fixes for any issues",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "apps/web/src/**/*.ts",
      "apps/web/src/**/*.tsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check for TypeScript issues in the saved file and suggest fixes if any problems are found"
  }
}
{
  "enabled": true,
  "name": "Python lint check",
  "description": "Runs ruff check on saved Python files in services/api/ and reports any linting errors",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "services/api/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "ruff check"
  }
}
# Co-Op — Environment Variables
# Copy this file to .env and fill in values before running docker compose.

# Database
DB_PASS=change-me-in-production
DATABASE_URL=postgresql+asyncpg://coop:${DB_PASS}@postgres:5432/coop

# Redis
REDIS_URL=redis://redis:6379/0

# Vector DB
QDRANT_URL=http://qdrant:6333

# Object Storage
MINIO_URL=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

# Security
SECRET_KEY=change-me-in-production

# Runtime
ENVIRONMENT=development

# --- Stage 2: LLM & Communication ---
# LITELLM_URL=http://litellm:4000
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# TELEGRAM_ADMIN_CHAT_ID=your-chat-id
# GROQ_API_KEY=gsk_your-groq-key
# GEMINI_API_KEY=your-gemini-key

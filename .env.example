# ============================================================================
# Co-Op OS v1.0.3 Root Environment Configuration
# ============================================================================
# This file is for reference only - it shows all environment variables
# used across the entire Co-Op OS system.
#
# For actual deployment:
# - Use infrastructure/docker/.env for Docker deployments
# - Use services/api/.env for backend-only development
# - Use apps/web/.env.local for frontend-only development
#
# Documentation: https://docs.co-op-os.ai/configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# PostgreSQL password for 'coop' user
DB_PASS=cooppassword123

# Full database connection string (auto-constructed in docker-compose)
DATABASE_URL=postgresql+asyncpg://coop:${DB_PASS}@postgres:5432/coop

# ----------------------------------------------------------------------------
# Redis Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# Redis connection URL for caching and task queues
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# MinIO Object Storage (REQUIRED)
# ----------------------------------------------------------------------------
# MinIO API endpoint (Docker internal network, no http:// prefix)
MINIO_URL=minio:9000

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ----------------------------------------------------------------------------
# Security (REQUIRED)
# ----------------------------------------------------------------------------
# JWT signing key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=super-secret-key-change-in-production-min-32-chars

# ----------------------------------------------------------------------------
# Service URLs (REQUIRED)
# ----------------------------------------------------------------------------
# Ollama LLM service endpoint
OLLAMA_URL=http://ollama:11434

# Backend API endpoint (internal Docker network)
API_BASE_URL=http://co-op-api:8000

# Frontend endpoint (internal Docker network)
FRONTEND_URL=http://co-op-web:3000

# LiteLLM gateway endpoint
LITELLM_URL=http://litellm:4000

# Qdrant vector database endpoint
QDRANT_URL=http://qdrant:6333

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Enable Qdrant vector search (true/false)
USE_QDRANT=false

# Enable simulation mode - no real actions taken (true/false)
COOP_SIMULATION_MODE=false

# Environment: local|development|staging|production
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# Log level: DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ----------------------------------------------------------------------------
# Stage 2 Features (Optional)
# ----------------------------------------------------------------------------
# Telegram bot token for notifications (get from @BotFather)
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram chat ID for admin alerts
# TELEGRAM_ADMIN_CHAT_ID=123456789

# Groq API key for LLM access
# GROQ_API_KEY=gsk_your-groq-api-key-here

# Google Gemini API key
# GEMINI_API_KEY=your-gemini-api-key-here

# Azure OpenAI API key (used by LiteLLM)
# AZURE_OPENAI_API_KEY=your-azure-openai-key

# ----------------------------------------------------------------------------
# Frontend Configuration (REQUIRED for web app)
# ----------------------------------------------------------------------------
# API URL accessible from browser (use localhost for local development)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default login email (development only, remove in production)
NEXT_PUBLIC_DEFAULT_EMAIL=admin@co-op.local

# Default login password (development only, remove in production)
NEXT_PUBLIC_DEFAULT_PASSWORD=testpass123

# Frontend environment
NEXT_PUBLIC_ENVIRONMENT=development

# ----------------------------------------------------------------------------
# CLI Configuration (Optional)
# ----------------------------------------------------------------------------
# Path to docker-compose.yml file
# COOP_COMPOSE_PATH=/path/to/docker-compose.yml

# Path to .env file
# COOP_ENV_FILE=/path/to/.env

# API URL for CLI commands
# COOP_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# CI/CD Configuration (GitHub Actions)
# ----------------------------------------------------------------------------
# These should be set as GitHub repository secrets/variables, not in .env files

# Repository Secrets (encrypted):
# - DB_PASS
# - MINIO_ROOT_PASSWORD
# - SECRET_KEY
# - TELEGRAM_BOT_TOKEN
# - GROQ_API_KEY
# - GEMINI_API_KEY
# - GHCR_TOKEN (GitHub Container Registry token)

# Repository Variables (plain text):
# - MINIO_ROOT_USER=minioadmin
# - OLLAMA_URL=http://ollama:11434
# - API_BASE_URL=http://co-op-api:8000
# - FRONTEND_URL=http://co-op-web:3000
# - LITELLM_URL=http://litellm:4000
# - QDRANT_URL=http://qdrant:6333
# - DOCKER_REGISTRY=ghcr.io
# - DOCKER_IMAGE_PREFIX=navaneethvvinod/co-op

# ----------------------------------------------------------------------------
# Installer Configuration (Optional)
# ----------------------------------------------------------------------------
# Installation directory
# COOP_INSTALL_DIR=$HOME/.co-op

# Docker Compose download URL
# COOP_COMPOSE_URL=https://raw.githubusercontent.com/NAVANEETHVVINOD/CO_OP/main/infrastructure/docker/docker-compose.yml

# .env.example download URL
# COOP_ENV_EXAMPLE_URL=https://raw.githubusercontent.com/NAVANEETHVVINOD/CO_OP/main/infrastructure/docker/.env.example

# ----------------------------------------------------------------------------
# Component-Specific Files
# ----------------------------------------------------------------------------
# For actual deployment, use these component-specific .env.example files:
#
# 1. infrastructure/docker/.env.example
#    - Complete Docker deployment configuration
#    - All services configured for Docker internal network
#    - Copy to infrastructure/docker/.env
#
# 2. services/api/.env.example
#    - Backend API configuration
#    - For standalone backend development
#    - Copy to services/api/.env
#
# 3. apps/web/.env.example
#    - Frontend configuration
#    - For standalone frontend development
#    - Copy to apps/web/.env.local
#
# ----------------------------------------------------------------------------
# Security Notes
# ----------------------------------------------------------------------------
# - Never commit .env files to version control
# - Change all default passwords and secrets in production
# - Use strong, randomly generated values for SECRET_KEY
# - Keep API keys and tokens secure
# - Remove development defaults (DEFAULT_EMAIL, DEFAULT_PASSWORD) in production
# - Use environment-specific .env files for different deployments
# - Regularly rotate secrets and credentials

# ============================================================================
# Co-Op API Backend Environment Variables
# ============================================================================
# Copy this file to .env and update values for your environment
# All variables listed here are used by services/api/app/config.py
# Documentation: https://docs.co-op-os.ai/configuration

# ----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# PostgreSQL connection string for async SQLAlchemy
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://coop:YOUR_PASSWORD@postgres:5432/coop

# PostgreSQL password for 'coop' user (must match DATABASE_URL password)
DB_PASS=YOUR_PASSWORD

# ----------------------------------------------------------------------------
# Redis Configuration (REQUIRED)
# ----------------------------------------------------------------------------
# Redis connection URL for caching and task queues
# Format: redis://host:port/db_number
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# MinIO Object Storage (REQUIRED)
# ----------------------------------------------------------------------------
# MinIO API endpoint (Docker internal network, no http:// prefix)
# For Docker: minio:9000
# For local development: localhost:9000
MINIO_URL=minio:9000

# MinIO root credentials for authentication
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ----------------------------------------------------------------------------
# Security (REQUIRED)
# ----------------------------------------------------------------------------
# JWT signing key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=super-secret-key-change-in-production-min-32-chars

# ----------------------------------------------------------------------------
# Service URLs (REQUIRED)
# ----------------------------------------------------------------------------
# Ollama LLM service endpoint
# For Docker: http://ollama:11434
# For local development: http://localhost:11434
OLLAMA_URL=http://ollama:11434

# Backend API base URL (used by CRONs/Telegram to call self)
# For Docker: http://co-op-api:8000
# For local development: http://localhost:8000
API_BASE_URL=http://localhost:8000

# Frontend URL (used for CORS configuration)
# For Docker: http://co-op-web:3000
# For local development: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# LiteLLM gateway endpoint (optional, but recommended)
# For Docker: http://litellm:4000
# For local development: http://localhost:4000
LITELLM_URL=http://litellm:4000

# Qdrant vector database endpoint (optional, only if USE_QDRANT=true)
# For Docker: http://qdrant:6333
# For local development: http://localhost:6333
QDRANT_URL=http://qdrant:6333

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Enable Qdrant vector search (true/false)
# Set to false to use BM25 search only
USE_QDRANT=false

# Enable simulation mode - no real actions taken (true/false)
# Useful for testing without side effects
COOP_SIMULATION_MODE=false

# Environment: local|development|staging|production
# Affects validation and logging behavior
ENVIRONMENT=local

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# Log level: DEBUG|INFO|WARNING|ERROR|CRITICAL
# Use DEBUG for development, INFO for production
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/settings/projects/
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ----------------------------------------------------------------------------
# Stage 2 Features (Optional)
# ----------------------------------------------------------------------------
# Telegram bot token for notifications (get from @BotFather)
# Leave empty to disable Telegram notifications
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram chat ID for admin alerts
# Get by messaging @userinfobot
# TELEGRAM_ADMIN_CHAT_ID=123456789

# Groq API key for LLM access
# Get from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-groq-api-key-here

# Google Gemini API key
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# - All REQUIRED variables must be set for the API to start
# - In production mode (ENVIRONMENT=production), validation is stricter
# - Service URLs should use Docker internal network names when running in Docker
# - For local development, use localhost URLs
# - Never commit .env files to version control
# - Keep SECRET_KEY, passwords, and API keys secure

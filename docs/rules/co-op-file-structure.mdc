│   ├── documents.py            ← POST/GET/DELETE /v1/documents
│   ├── search.py               ← POST /v1/search
│   ├── health.py               ← GET /health, /ready, /metrics
│   ├── approvals.py            ← Stage 3: full HITL approval system
│   └── company_setup.py        ← Stage 2: Company Profile wizard API
│
├── agent/
│   ├── graph.py                ← LangGraph StateGraph
│   ├── nodes.py                ← retrieve, rerank, generate nodes
│   ├── state.py                ← AgentState TypedDict
│   ├── lead_scout.py           ← Stage 2: Upwork job finder
│   ├── proposal_writer.py      ← Stage 3: Proposal drafting
│   ├── outreach_manager.py     ← Stage 3: Submit proposals
│   ├── client_communicator.py  ← Stage 3: Handle client emails
│   ├── project_tracker.py      ← Stage 3: Milestone tracking
│   ├── finance_manager.py      ← Stage 3: Invoice creation
│   └── research_agent.py       ← Stage 3: GitHub/HF scanning
│
├── communication/              ← Stage 2: Telegram adapter
│   ├── telegram.py             ← Bot commands + handlers
│   └── progress.py             ← Thinking display publisher
│
├── core/
│   ├── embedder.py             ← all-MiniLM-L6-v2 wrapper
│   ├── minio_client.py         ← MinIO upload/download
│   ├── redis_client.py         ← Redis connection
│   ├── security.py             ← JWT encode/decode
│   ├── logging.py              ← Structured logging
│   ├── hardware_detector.py    ← Stage 2: HW tier detection
│   └── docker_sandbox.py       ← Stage 3: Safe code execution
│
├── db/
│   ├── models.py               ← SQLAlchemy ORM models
│   ├── repositories.py         ← Repository pattern
│   ├── session.py              ← Async engine + session
│   └── qdrant_client.py        ← Qdrant async client
│
├── events/
│   └── consumer.py             ← Redis Streams XREADGROUP consumer
│
